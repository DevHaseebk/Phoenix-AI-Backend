generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model FoundationMigrationCheck {
  id        String   @id @default(uuid())
  label     String   @unique
  createdAt DateTime @default(now())

  @@map("foundation_migration_checks")
}
