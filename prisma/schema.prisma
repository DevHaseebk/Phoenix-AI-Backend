generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum GoalType {
  LOSE_WEIGHT
  MAINTAIN_WEIGHT
  GAIN_WEIGHT
}

enum GoalPace {
  SLOW
  BALANCED
  AGGRESSIVE
}

enum ActivityLevel {
  SEDENTARY
  LIGHTLY_ACTIVE
  MODERATELY_ACTIVE
  VERY_ACTIVE
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum WeightLogSource {
  MANUAL
  ONBOARDING
  IMPORTED
}

enum WaterLogSource {
  MANUAL
  QUICK_ADD
  IMPORTED
}

enum ExerciseLogSource {
  MANUAL
  DEVICE
  IMPORTED
}

enum ExerciseType {
  WALKING
  RUNNING
  CYCLING
  STRENGTH
  CARDIO
  SPORTS
  STEPS
  OTHER
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  CUSTOM
}

enum MealLogSource {
  MANUAL
  AI_CHAT
  WHATSAPP
  IMPORTED
}

enum MealLogStatus {
  LOGGED
  ESTIMATED
  NEEDS_REVIEW
}

enum ConfidenceLevel {
  LOW
  MEDIUM
  HIGH
  VERIFIED
}

enum AiConversationType {
  COACHING
  MEAL_LOGGING
}

enum AiConversationStatus {
  ACTIVE
  ARCHIVED
}

enum AiMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AiMealEstimateStatus {
  DRAFT
  NEEDS_CLARIFICATION
  CONFIRMED
  DISCARDED
}

model FoundationMigrationCheck {
  id        String   @id @default(uuid())
  label     String   @unique
  createdAt DateTime @default(now())

  @@map("foundation_migration_checks")
}

model User {
  id              String           @id @default(uuid())
  email           String?          @unique
  passwordHash    String?
  fullName        String?
  phone           String?          @unique
  status          UserStatus       @default(ACTIVE)
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  lastActiveAt    DateTime?
  deletedAt       DateTime?
  profile         UserProfile?
  onboarding      UserOnboarding?
  weightLogs      WeightLog[]
  waterLogs       WaterLog[]
  exerciseLogs    ExerciseLog[]
  mealLogs        MealLog[]
  aiConversations AiConversation[]
  aiMessages      AiMessage[]
  aiMealEstimates AiMealEstimate[]
  aiMemories      AiMemory[]
  notifications   Notification[]
  mealPlans       MealPlan[]
  weeklyReviews   WeeklyReview[]
  userBadges      UserBadge[]
  refreshTokens   RefreshToken[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([lastActiveAt])
  @@index([deletedAt])
  @@map("users")
}

model UserProfile {
  id                 String         @id @default(uuid())
  userId             String         @unique
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  gender             Gender?
  dateOfBirth        DateTime?
  heightCm           Decimal?
  currentWeightKg    Decimal?
  targetWeightKg     Decimal?
  goalType           GoalType       @default(LOSE_WEIGHT)
  goalPace           GoalPace       @default(BALANCED)
  activityLevel      ActivityLevel?
  timezone           String?        @default("Asia/Karachi")
  preferredLanguage  String?        @default("en")
  calorieTarget      Decimal?
  proteinTargetGrams Decimal?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@map("user_profiles")
}

model UserOnboarding {
  id             String           @id @default(uuid())
  userId         String           @unique
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         OnboardingStatus @default(NOT_STARTED)
  currentStep    String?
  completedSteps Json             @default("[]")
  draft          Json             @default("{}")
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status])
  @@map("user_onboarding")
}

model WeightLog {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg  Decimal
  loggedAt  DateTime
  source    WeightLogSource @default(MANUAL)
  note      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId])
  @@index([loggedAt])
  @@index([userId, loggedAt])
  @@map("weight_logs")
}

model WaterLog {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountMl  Int
  loggedAt  DateTime
  source    WaterLogSource @default(MANUAL)
  note      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId])
  @@index([loggedAt])
  @@index([userId, loggedAt])
  @@map("water_logs")
}

model ExerciseLog {
  id                      String            @id @default(uuid())
  userId                  String
  user                    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseType            ExerciseType
  durationMinutes         Int
  steps                   Int?
  distanceKm              Decimal?
  estimatedCaloriesBurned Int?
  loggedAt                DateTime
  source                  ExerciseLogSource @default(MANUAL)
  note                    String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  @@index([userId])
  @@index([loggedAt])
  @@index([userId, loggedAt])
  @@map("exercise_logs")
}

model MealLog {
  id                String          @id @default(uuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealType          MealType
  loggedAt          DateTime
  source            MealLogSource   @default(MANUAL)
  status            MealLogStatus   @default(LOGGED)
  confidenceLevel   ConfidenceLevel @default(VERIFIED)
  description       String?
  note              String?
  totalCalories     Decimal
  totalProteinGrams Decimal
  totalCarbsGrams   Decimal?
  totalFatGrams     Decimal?
  items             MealLogItem[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([userId])
  @@index([loggedAt])
  @@index([mealType])
  @@index([userId, loggedAt])
  @@map("meal_logs")
}

model MealLogItem {
  id              String          @id @default(uuid())
  mealLogId       String
  mealLog         MealLog         @relation(fields: [mealLogId], references: [id], onDelete: Cascade)
  foodName        String
  portionLabel    String?
  quantity        Decimal?
  calories        Decimal
  proteinGrams    Decimal
  carbsGrams      Decimal?
  fatGrams        Decimal?
  confidenceLevel ConfidenceLevel @default(VERIFIED)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([mealLogId])
  @@map("meal_log_items")
}

model AiConversation {
  id            String               @id @default(uuid())
  userId        String
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String?
  type          AiConversationType   @default(COACHING)
  status        AiConversationStatus @default(ACTIVE)
  messages      AiMessage[]
  mealEstimates AiMealEstimate[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([updatedAt])
  @@map("ai_conversations")
}

model AiMessage {
  id             String           @id @default(uuid())
  conversationId String
  conversation   AiConversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           AiMessageRole
  content        String
  structured     Json?
  model          String?
  tokenInput     Int?
  tokenOutput    Int?
  latencyMs      Int?
  safetyFlags    Json?
  mealEstimates  AiMealEstimate[]
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@index([userId])
  @@index([createdAt])
  @@map("ai_messages")
}

model AiMealEstimate {
  id                     String               @id @default(uuid())
  userId                 String
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId         String?
  conversation           AiConversation?      @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  messageId              String?
  message                AiMessage?           @relation(fields: [messageId], references: [id], onDelete: SetNull)
  originalText           String
  mealType               MealType?
  status                 AiMealEstimateStatus @default(DRAFT)
  confidenceLevel        ConfidenceLevel
  confidenceScore        Float?
  calories               Int?
  proteinGrams           Float?
  carbsGrams             Float?
  fatGrams               Float?
  fiberGrams             Float?
  items                  Json
  clarificationQuestions Json?
  assumptions            Json?
  warnings               Json?
  confirmedAt            DateTime?
  mealLogId              String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([userId])
  @@index([conversationId])
  @@index([messageId])
  @@index([status])
  @@map("ai_meal_estimates")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  deviceName String?
  deviceType String?
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

enum RagDocumentCategory {
  PAKISTANI_FOODS
  PLATEAU_HANDLING
  WALKING_GUIDE
  PROTEIN_GUIDE
  BEHAVIOR_RULES
  RAMADAN_GUIDE
  SAFETY_BOUNDARIES
  FLEXIBLE_MEALS
  RESTAURANT_NOTES
}

enum RagDocumentStatus {
  DRAFT
  APPROVED
  ARCHIVED
}

model RagDocument {
  id        String              @id @default(uuid())
  category  RagDocumentCategory
  title     String
  content   String
  status    RagDocumentStatus   @default(DRAFT)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  chunks RagChunk[]

  @@index([category, status])
  @@map("rag_documents")
}

// SAFE MIGRATIONS: this model has a manual ivfflat vector index
// (rag_chunks_embedding_idx) that Prisma cannot see because `embedding` is
// an Unsupported("vector") column. Plain `prisma migrate dev` will treat that
// index as drift and propose dropping it. Always run
// `npm run db:migrate:safe` (--create-only), hand-inspect the generated SQL,
// and remove any DROP INDEX / unrelated-model statements before applying.
// Full rule: docs/12_Migration_Safety_Notes.md
model RagChunk {
  id         String                 @id @default(uuid())
  documentId String
  document   RagDocument            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex Int
  content    String
  embedding  Unsupported("vector(768)")?
  tokenCount Int
  createdAt  DateTime               @default(now())

  @@unique([documentId, chunkIndex])
  @@map("rag_chunks")
}

enum AiMemoryCategory {
  PERMANENT_PROFILE
  FOOD_PREFERENCE
  PORTION_PATTERN
  BEHAVIORAL_PATTERN
  MOTIVATION_STYLE
  TEMPORARY_LIFE_EVENT
  MILESTONE
  EMOTIONAL_SUPPORT_PATTERN
}

enum AiMemoryStatus {
  ACTIVE
  ARCHIVED
}

// SAFE MIGRATIONS: this model has a manual ivfflat vector index
// (ai_memories_embedding_idx) invisible to Prisma's diffing for the same
// reason as RagChunk above. See that comment and docs/12_Migration_Safety_Notes.md.
model AiMemory {
  id            String                 @id @default(uuid())
  userId        String
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      AiMemoryCategory
  content       String
  embedding     Unsupported("vector(768)")?
  confidence    Float                  @default(0.6)
  isUserVisible Boolean                @default(true)
  status        AiMemoryStatus         @default(ACTIVE)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([userId, category])
  @@map("ai_memories")
}

enum NotificationType {
  WEIGHT_UPDATE_DUE
  MEAL_LOGGING_GAP
  WATER_TARGET_CLOSE
  COMEBACK_WELCOME
  BADGE_UNLOCKED
}

enum NotificationStatus {
  UNREAD
  READ
  DISMISSED
}

model Notification {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  message   String
  status    NotificationStatus @default(UNREAD)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([userId, status, createdAt])
  @@map("notifications")
}

// Food Intelligence Engine (docs/02_Product_Bible.md §18, docs/04_Technical_Architecture.md §19).
// FoodItem/FoodAlias are the structured Food DB; UnknownFoodQueueItem captures
// foods estimateMeal() could not confidently match, for later founder review.
enum FoodCategory {
  MAIN_DISH
  SNACK
  BEVERAGE
  BREAD
  PROTEIN
  VEGETABLE
  FRUIT
  DAIRY
  OTHER
}

enum FoodDataConfidence {
  LOW
  MEDIUM
  HIGH
}

enum FoodSource {
  USDA
  PHOENIX_DB
  FOUNDER_REVIEWED
  AI_ESTIMATE
}

enum UnknownFoodQueueStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_RESEARCH
}

model FoodItem {
  id                        String             @id @default(uuid())
  name                      String
  category                  FoodCategory       @default(OTHER)
  caloriesPer100g           Decimal
  proteinPer100g            Decimal
  carbsPer100g              Decimal?
  fatPer100g                Decimal?
  defaultServingDescription String
  defaultServingGrams       Decimal
  confidence                FoodDataConfidence @default(MEDIUM)
  source                    FoodSource
  verified                  Boolean            @default(false)
  aliases                   FoodAlias[]
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  @@index([name])
  @@map("food_items")
}

// Every FoodItem must have at least one alias equal to its own normalized
// name (created alongside the item) so resolveFoodMatch() only ever needs to
// query this one table - see backend/src/ai/food/food-matching.service.ts.
model FoodAlias {
  id         String   @id @default(uuid())
  foodItemId String
  foodItem   FoodItem @relation(fields: [foodItemId], references: [id], onDelete: Cascade)
  alias      String

  @@unique([foodItemId, alias])
  @@index([alias])
  @@map("food_aliases")
}

model UnknownFoodQueueItem {
  id                  String                  @id @default(uuid())
  // Normalized (lowercase, trimmed, punctuation-stripped) text, not the raw
  // user string - lets repeat sightings of the same food increment frequency
  // instead of creating duplicate rows.
  rawText             String                  @unique
  aiSuggestedEstimate Json?
  confidence          FoodDataConfidence?
  frequency           Int                     @default(1)
  lastSeenAt          DateTime                @default(now())
  suggestedCategory   FoodCategory?
  status              UnknownFoodQueueStatus  @default(PENDING)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([status])
  @@index([frequency])
  @@map("unknown_food_queue_items")
}

// Planning Mode (docs/02_Product_Bible.md §15.7): persisted 7-day meal plans
// with a flexible meal count per day and a derived grocery checklist.
enum MealPlanStatus {
  ACTIVE
  ARCHIVED
}

// Where a planned meal's selection came from: picked from the FoodItem
// database (regardless of that item's own FoodSource), or generated by the
// AI fallback when no suitable DB match existed for the slot's budget.
enum PlannedMealSource {
  FOOD_DB
  AI_ESTIMATE
}

model MealPlan {
  id            String            @id @default(uuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Local date (user's timezone) the 7-day plan starts on; plannedMeals'
  // dayOfWeek is a 0-6 offset from this date, not a calendar weekday.
  weekStartDate DateTime
  status        MealPlanStatus    @default(ACTIVE)
  plannedMeals  PlannedMeal[]
  groceryItems  GroceryListItem[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId, status])
  @@map("meal_plans")
}

model PlannedMeal {
  id              String            @id @default(uuid())
  mealPlanId      String
  mealPlan        MealPlan          @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  dayOfWeek       Int
  mealSlotIndex   Int
  mealSlotLabel   String
  foodDescription String
  calories        Decimal
  proteinGrams    Decimal
  carbsGrams      Decimal?
  fatGrams        Decimal?
  source          PlannedMealSource
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([mealPlanId, dayOfWeek])
  @@map("planned_meals")
}

model GroceryListItem {
  id         String   @id @default(uuid())
  mealPlanId String
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  itemName   String
  note       String?
  checked    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([mealPlanId])
  @@map("grocery_list_items")
}

// Simplified from docs/09_Database_Schema.md §11.2: no DailySummary cache
// table (that design assumes a nightly job; no cron/job infra exists in this
// repo - see CLAUDE.md §8). All stats are computed on-demand at generation
// time from raw logs (see ai/review/weekly-review-stats.util.ts) and only
// the final WeeklyReview result is persisted, for history. generatedByProvider
// is a plain string (e.g. "gemini"/"local"), not an enum - no AIProvider enum
// exists anywhere else in this schema either.
model WeeklyReview {
  id                  String    @id @default(uuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStartDate       DateTime
  weekEndDate         DateTime

  avgCalories         Decimal?
  avgProteinGrams     Decimal?
  avgSteps            Decimal?
  avgWaterMl          Decimal?
  startWeightKg       Decimal?
  endWeightKg         Decimal?
  weightChangeKg      Decimal?
  consistencyRate     Decimal?

  // AI narrative. aiRecommendations also carries whatWorked/whatGotDifficult/
  // nextWeekFocus/bestHabit/weakestHabit - see review.service.ts - rather than
  // adding a column per field, since this is inherently one AI-shaped bundle.
  aiSummary           String?
  aiRecommendations   Json?
  generatedByProvider String?
  generatedAt         DateTime?
  viewedAt            DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([userId, weekStartDate])
  @@index([weekStartDate, weekEndDate])
  @@map("weekly_reviews")
}

// Rewards/Badge Engine (docs/02_Product_Bible.md §22, docs/17_Rewards_Badge_Design.md).
// Badge definitions themselves are a static, typed config array in code
// (backend/src/ai/rewards/badge-definitions.ts), NOT database rows - badgeKey
// here just references that config's `key` field. This is the only new table:
// one row per badge a user has actually unlocked.
model UserBadge {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeKey   String
  unlockedAt DateTime @default(now())

  @@unique([userId, badgeKey])
  @@index([userId])
  @@map("user_badges")
}
