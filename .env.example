NODE_ENV=development
PORT=4000

# Comma-separated list of allowed frontend origins (whitespace around each
# entry is trimmed). Optional - when unset, development/test fall back to
# the localhost defaults in main.ts's parseAllowedOrigins(), and production
# allows no origins at all until this is set. Include every deployed
# frontend URL here, e.g. for this project's Vercel deployment:
# CORS_ORIGINS=http://localhost:3000,https://phoenix-ai-frontend-three.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

DATABASE_URL=
DIRECT_URL=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_PROVIDER=gemini
AI_ENABLED=true
AI_TIMEOUT_MS=30000

RESEND_API_KEY=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Free key from https://fdc.nal.usda.gov/api-key-signup.html - only needed to
# run prisma/usda-import.ts (generic/global food seeding). Not required for
# the app itself to run.
USDA_API_KEY=

# Subscription/Trial flow (Stripe test mode) - all optional; billing
# endpoints return a clear "not configured" error when unset, same pattern
# as GOOGLE_CLIENT_ID. Get test-mode keys from https://dashboard.stripe.com/test/apikeys
# and a webhook signing secret from `stripe listen` (CLI) or a configured
# test-mode webhook endpoint. STRIPE_PRICE_ID is the single Pro-tier Price ID.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# Used to build Stripe Checkout/Portal success/cancel/return redirect URLs.
FRONTEND_URL=http://localhost:3000

# Admin Panel Foundation - optional. If set, the first time a user with this
# exact email logs in (email/password or Google) they are promoted to
# role: ADMIN automatically, so the founder account never needs manual DB
# editing to bootstrap the first admin.
ADMIN_BOOTSTRAP_EMAIL=
