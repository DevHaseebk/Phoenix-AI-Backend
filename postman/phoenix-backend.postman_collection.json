      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "description": "Creates a new email/password account. Signup does not currently return tokens.",
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "signup"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Haseeb Khan\",\n  \"email\": \"haseeb@example.com\",\n  \"password\": \"StrongPassword123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  const data = json && json.data ? json.data : {};",
                  "  const tokens = data.tokens || {};",
                  "  const accessToken = data.accessToken || tokens.accessToken;",
                  "  const refreshToken = data.refreshToken || tokens.refreshToken;",
                  "  const user = data.user || data;",
                  "  if (accessToken) {",
                  "    pm.collectionVariables.set('accessToken', accessToken);",
                  "    if (pm.environment) pm.environment.set('accessToken', accessToken);",
                  "  }",
                  "  if (refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', refreshToken);",
                  "    if (pm.environment) pm.environment.set('refreshToken', refreshToken);",
                  "  }",
                  "  if (user && user.id) {",
                  "    pm.collectionVariables.set('currentUserId', user.id);",
                  "    if (pm.environment) pm.environment.set('currentUserId', user.id);",
                  "  }",
                  "} catch (error) {",
                  "  // Defensive: do not fail if response shape changes or body is not JSON.",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "description": "Logs in and automatically stores accessToken, refreshToken, and currentUserId for protected requests.",
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"haseeb@example.com\",\n  \"password\": \"StrongPassword123\",\n  \"device\": {\n    \"deviceName\": \"Postman on Desktop\",\n    \"deviceType\": \"WEB\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  const data = json && json.data ? json.data : {};",
                  "  if (data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', data.accessToken);",
                  "    if (pm.environment) pm.environment.set('accessToken', data.accessToken);",
                  "  }",
                  "} catch (error) {",
                  "  // Defensive: do not fail if response shape changes or body is not JSON.",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "description": "Uses refreshToken to get and store a new accessToken.",
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  ['accessToken', 'refreshToken'].forEach((key) => {",
                  "    pm.collectionVariables.unset(key);",
                  "    if (pm.environment) pm.environment.unset(key);",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "description": "Revokes refreshToken and clears local Postman token variables on success.",
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        }
      ]
    },
