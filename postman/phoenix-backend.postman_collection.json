              ]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  const data = json && json.data ? json.data : {};",
                  "  const tokens = data.tokens || {};",
                  "  const accessToken = data.accessToken || tokens.accessToken;",
                  "  const refreshToken = data.refreshToken || tokens.refreshToken;",
                  "",
                  "  if (accessToken) {",
                  "    pm.collectionVariables.set('accessToken', accessToken);",
                  "    if (pm.environment) pm.environment.set('accessToken', accessToken);",
                  "  }",
                  "",
                  "  if (refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', refreshToken);",
                  "    if (pm.environment) pm.environment.set('refreshToken', refreshToken);",
                  "  }",
                  "} catch (error) {",
                  "  // Defensive by design: do not fail if response is not JSON or token shape changes.",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"haseeb@example.com\",\n  \"password\": \"StrongPassword123\",\n  \"device\": {\n    \"deviceName\": \"Postman on Desktop\",\n    \"deviceType\": \"WEB\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Logs in with email/password and defensively stores accessToken and refreshToken when present.",
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  const data = json && json.data ? json.data : {};",
                  "  if (data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', data.accessToken);",
                  "    if (pm.environment) pm.environment.set('accessToken', data.accessToken);",
                  "  }",
                  "} catch (error) {",
                  "  // Defensive by design: do not fail if response is not JSON or token shape changes.",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Uses the opaque refresh token to get a new access token. Refresh token rotation is deferred.",
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Idempotently revokes the opaque refresh token by setting revokedAt when it exists.",
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            }
          },
          "response": []
        }
      ]
